<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:settings="http://schemas.android.com/apk/res-auto"
        android:key="misc_settings"
        android:title="@string/misc_settings_title">

    <!-- Battery Custs -->
    <Preference
        android:key="battery_custs"
        android:title="@string/battery_custs_title"
        android:summary="@string/battery_custs_summary"
        android:fragment="com.android.settings.aospb.misc.batteryCusts" />

    <!-- Cache Cleaner -->
    <ListPreference
        android:key="cache_cleaner_interval"
        android:title="@string/cache_cleaner_title"
        android:summary="Choose how often storage cache should be cleared."
        android:defaultValue="-1"
        android:persistent="false"
        android:entries="@array/cache_cleaner_intervals"
        android:entryValues="@array/cache_cleaner_interval_values"
        android:dialogTitle="@string/cache_cleaner_dialog" />
</PreferenceScreen>
